tellraw @s [{"text":"🎨 油漆大战 — 游戏帮助文档\n","color":"aqua","bold":true},{"text":"\n"},{"text":"游戏简介\n","color":"gold","bold":true},{"text":"玩家需要利用道具扩充自己的颜色地块，或阻止其他玩家扩充他们的颜色地块。\n"},{"text":"游戏时间：3 分钟，结束时地块最多的玩家获胜。\n"},{"text":"每种颜色只能一个玩家，站到对应颜色位置选择队伍。\n"},{"text":"复活时间：5 秒。\n"},{"text":"道具发放：从游戏开始，每 1 分钟随机发放一次道具。\n"},{"text":"\n"},{"text":"游戏道具\n","color":"gold","bold":true},{"text":"1. 油漆炸弹 ","color":"red"},{"text":"— 以落地点为中心 5×5 区域染成自己的颜色。\n"},{"text":"2. 油漆地雷 ","color":"yellow"},{"text":"— 在落地点部署地雷，非己方单位经过时造成大量伤害和减速，并将 5×5 区域染成自己的颜色。\n"},{"text":"3. 油漆守护弹 ","color":"green"},{"text":"— 在落地点部署守护弹，10 秒内保护以自身为中心 9×9 区域的颜色不被改变。\n"},{"text":"   己方单位在其中：快速恢复生命值\n"},{"text":"   敌方单位在其中：快速失去生命值\n"},{"text":"4. 神龟药水 ","color":"blue"},{"text":"— 在落地的区域生成小范围药水区域，持续 2 秒，区域内所有玩家速度大幅降低、防御大幅提升，效果持续 5 秒。\n"},{"text":"5. 秒人斧_MAX ","color":"dark_purple"},{"text":"— 绝对隐藏武器，效果拔群，出现概率 ?% 。\n"},{"text":"6. 油漆桶 ","color":"gold"},{"text":"— 位于场地正中央，第一个站上去并成功染色的玩家能将 21×21 区域染成自己的颜色。\n"},{"text":"\n"},{"text":"游戏操作指令\n","color":"gold","bold":true},{"text":"/trigger battlepaint_tplobby — 返回大厅 / 重新选择颜色 / 退出游戏\n"},{"text":"/trigger battlepaint_start — 开始游戏，开启前确保所有玩家已选择颜色加入游戏。\n"},{"text":"\n"},{"text":"🎉 玩得愉快，祝你称霸油漆大战！\n","color":"aqua","bold":true}]
